{
  "__inputs": [],
  "__requires": [
    {
      "id": "grafana",
      "name": "Grafana",
      "type": "grafana",
      "version": "8.0.0"
    },
    {
      "id": "prometheus",
      "name": "Prometheus",
      "type": "datasource",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Claude Code metrics \u2014 cost, tokens, sessions, active time, lines of code, tool decisions",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "options": {
        "mode": "html",
        "content": "<div style=\"font-size:14px;line-height:1.6\"><h3 style=\"margin:0 0 8px\">Claude Code \u2014 Live Activity</h3><p style=\"margin:0;color:#999\">Real-time metrics for Claude Code sessions. Cost, token usage, cache efficiency, active time, code changes, and tool decisions.</p><p style=\"margin:4px 0 0;color:#666;font-size:12px\">\ud83d\udca1 Use the time picker to adjust the window. Stat panels show totals for the selected range.</p></div>"
      },
      "title": "",
      "transparent": true,
      "type": "text"
    },
    {
      "collapsed": false,
      "description": "Key metrics at a glance for the selected time range",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total USD spent across all models in the selected time range",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 4
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range]))",
          "legendFormat": "Total Cost",
          "refId": "A"
        }
      ],
      "title": "Total Cost",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Number of Claude Code sessions started",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 4,
        "y": 4
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_session_count_total[$__range]))",
          "legendFormat": "Sessions",
          "refId": "A"
        }
      ],
      "title": "Sessions",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Sum of all token types (input, output, cache read, cache creation)",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "purple",
            "mode": "fixed"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "purple",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 8,
        "y": 4
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total[$__range]))",
          "legendFormat": "Total Tokens",
          "refId": "A"
        }
      ],
      "title": "Total Tokens",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total seconds Claude Code was actively processing",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "orange",
            "mode": "fixed"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": null
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 12,
        "y": 4
      },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_active_time_seconds_total[$__range]))",
          "legendFormat": "Active Time",
          "refId": "A"
        }
      ],
      "title": "Active Time",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total lines of code added by Claude Code",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 16,
        "y": 4
      },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_lines_of_code_count_total{type=\"added\"}[$__range]))",
          "legendFormat": "Lines Added",
          "refId": "A"
        }
      ],
      "title": "Lines Added",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Total lines of code removed by Claude Code",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 4
      },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_lines_of_code_count_total{type=\"removed\"}[$__range]))",
          "legendFormat": "Lines Removed",
          "refId": "A"
        }
      ],
      "title": "Lines Removed",
      "type": "stat"
    },
    {
      "collapsed": false,
      "description": "Cost and token usage trends with model and type breakdowns",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 8,
      "title": "Cost & Tokens",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "5-minute stacked cost showing which model contributes to spend over time.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "spanNulls": false,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      },
      "id": 10,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (model)(increase(claude_code_cost_usage_USD_total[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Cost by Model (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "5-minute token consumption by type (input, output, cache read, cache creation).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "spanNulls": false
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "id": 14,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{type=\"input\"}[5m]))",
          "legendFormat": "Input",
          "refId": "A"
        },
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{type=\"output\"}[5m]))",
          "legendFormat": "Output",
          "refId": "B"
        },
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m]))",
          "legendFormat": "Cache Read",
          "refId": "C"
        },
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{type=\"cacheCreation\"}[5m]))",
          "legendFormat": "Cache Creation",
          "refId": "D"
        }
      ],
      "title": "Token Usage Over Time (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Pie chart showing proportional cost split between models.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 18
      },
      "id": 12,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (model)(increase(claude_code_cost_usage_USD_total[$__range]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Cost Distribution by Model",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Proportional split of all token types across the range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 18
      },
      "id": 18,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (type)(increase(claude_code_token_usage_tokens_total[$__range]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "title": "Token Distribution by Type",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Percentage of input tokens served from cache. Higher is better. Red <50%, Yellow 50-80%, Green >80%.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "fillOpacity": 15,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 18
      },
      "id": 16,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m])) / (sum(increase(claude_code_token_usage_tokens_total{type=\"input\"}[5m])) + sum(increase(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m])))",
          "legendFormat": "Cache Hit Ratio",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Ratio (%)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "description": "Lines of code added and removed over time",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "id": 24,
      "title": "Code Changes",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Bar chart showing lines added (green, positive) and removed (red, negative) per 5-minute window.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "opacity",
            "lineWidth": 0,
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Added"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Removed"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 26
      },
      "id": 25,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_lines_of_code_count_total{type=\"added\"}[5m]))",
          "legendFormat": "Added",
          "refId": "A"
        },
        {
          "expr": "-sum(increase(claude_code_lines_of_code_count_total{type=\"removed\"}[5m]))",
          "legendFormat": "Removed",
          "refId": "B"
        }
      ],
      "title": "Lines of Code Over Time (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Lines added minus removed. Green = net positive, Red = net negative.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 26
      },
      "id": 26,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(claude_code_lines_of_code_count_total{type=\"added\"}[$__range])) - sum(increase(claude_code_lines_of_code_count_total{type=\"removed\"}[$__range]))",
          "legendFormat": "Net Lines",
          "refId": "A"
        }
      ],
      "title": "Net Lines Changed",
      "type": "stat"
    },
    {
      "collapsed": false,
      "description": "Which tools Claude Code uses and how decisions are made",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "id": 27,
      "title": "Tool Decisions",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Top 10 tools by total invocation count in the selected range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 35
      },
      "id": 28,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (tool_name) (increase(claude_code_code_edit_tool_decision_total[$__range])))",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "title": "Tool Usage by Name (top 10)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Proportional breakdown of accept/reject/error decisions.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 35
      },
      "id": 29,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum by (decision) (increase(claude_code_code_edit_tool_decision_total[$__range]))",
          "legendFormat": "{{decision}}",
          "refId": "A"
        }
      ],
      "title": "Decisions by Type",
      "type": "piechart"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": [
    "claude-code",
    "observability"
  ],
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Claude Code",
  "uid": "claude-code-metrics",
  "version": 16
}
