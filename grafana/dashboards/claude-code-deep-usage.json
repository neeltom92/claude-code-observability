{
  "__inputs": [],
  "__requires": [
    {
      "id": "grafana",
      "name": "Grafana",
      "type": "grafana",
      "version": "8.0.0"
    },
    {
      "id": "prometheus",
      "name": "Prometheus",
      "type": "datasource",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "Claude Code model-level breakdown \u2014 cost, tokens, and efficiency per model",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "icon": "dashboard",
      "tags": ["claude-code"],
      "title": "Claude Code Dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Model Cost Breakdown",
      "type": "row"
    },
    {
      "datasource": null,
      "description": "Total cost per model in the selected time range",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        },
        "pieType": "donut",
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (model)(increase(claude_code_cost_usage_USD_total[$__range]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Cost Share by Model",
      "type": "piechart"
    },
    {
      "datasource": null,
      "description": "Cumulative cost per model over time (5m rate)",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 30,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (model)(increase(claude_code_cost_usage_USD_total[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Cost Over Time by Model (5m)",
      "type": "timeseries"
    },
    {
      "datasource": null,
      "description": "Table of cost per model with totals",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Model" },
            "properties": [{ "id": "custom.width", "value": 250 }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 9 },
      "id": 4,
      "options": {
        "footer": {
          "enablePagination": false,
          "reducer": ["sum"],
          "show": true
        },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Value" }]
      },
      "targets": [
        {
          "expr": "sum by (model)(increase(claude_code_cost_usage_USD_total[$__range]))",
          "legendFormat": "{{model}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "title": "Cost by Model (table)",
      "type": "table",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "model": "Model", "Value": "Cost (USD)" }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 10,
      "title": "Token Usage by Model",
      "type": "row"
    },
    {
      "datasource": null,
      "description": "Total tokens consumed per model, broken down by token type",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 11,
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (model)(increase(claude_code_token_usage_tokens_total{type=\"input\"}[5m]))",
          "legendFormat": "{{model}} input",
          "refId": "A"
        },
        {
          "expr": "sum by (model)(increase(claude_code_token_usage_tokens_total{type=\"output\"}[5m]))",
          "legendFormat": "{{model}} output",
          "refId": "B"
        }
      ],
      "title": "Input & Output Tokens by Model (5m)",
      "type": "timeseries"
    },
    {
      "datasource": null,
      "description": "Cache read vs cache creation tokens per model",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 12,
      "options": {
        "legend": {
          "calcs": ["sum"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (model)(increase(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m]))",
          "legendFormat": "{{model}} cache read",
          "refId": "A"
        },
        {
          "expr": "sum by (model)(increase(claude_code_token_usage_tokens_total{type=\"cacheCreation\"}[5m]))",
          "legendFormat": "{{model}} cache creation",
          "refId": "B"
        }
      ],
      "title": "Cache Tokens by Model (5m)",
      "type": "timeseries"
    },
    {
      "datasource": null,
      "description": "Total tokens by model — donut shows which model consumes the most tokens",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 26 },
      "id": 13,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        },
        "pieType": "donut",
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (model)(increase(claude_code_token_usage_tokens_total[$__range]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Token Share by Model",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 20,
      "title": "Model Efficiency",
      "type": "row"
    },
    {
      "datasource": null,
      "description": "Cache hit ratio per model — higher is better. Shows how effectively each model leverages cached context.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "id": 21,
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (model)(increase(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m])) / (sum by (model)(increase(claude_code_token_usage_tokens_total{type=\"input\"}[5m])) + sum by (model)(increase(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m])))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Cache Hit Ratio by Model (5m)",
      "type": "timeseries"
    },
    {
      "datasource": null,
      "description": "Cost per 1K output tokens by model — lower is more cost-efficient",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "spanNulls": false
          },
          "unit": "currencyUSD",
          "decimals": 4
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "id": 22,
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "(sum by (model)(increase(claude_code_cost_usage_USD_total[5m]))) / (sum by (model)(increase(claude_code_token_usage_tokens_total{type=\"output\"}[5m])) / 1000)",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Cost per 1K Output Tokens by Model (5m)",
      "type": "timeseries"
    },
    {
      "datasource": null,
      "description": "Output tokens generated per dollar spent, by model — higher is more efficient",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "spanNulls": false
          },
          "decimals": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 43 },
      "id": 23,
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (model)(increase(claude_code_token_usage_tokens_total{type=\"output\"}[5m])) / sum by (model)(increase(claude_code_cost_usage_USD_total[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Output Tokens per Dollar by Model (5m)",
      "type": "timeseries"
    },
    {
      "datasource": null,
      "description": "Input-to-output ratio per model — how many input tokens per output token. Lower may indicate more efficient prompting.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineWidth": 2,
            "spanNulls": false
          },
          "decimals": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 43 },
      "id": 24,
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum by (model)(increase(claude_code_token_usage_tokens_total{type=\"input\"}[5m])) / sum by (model)(increase(claude_code_token_usage_tokens_total{type=\"output\"}[5m]))",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "title": "Input:Output Token Ratio by Model (5m)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["claude-code", "observability", "model-usage"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Claude Code \u2014 Deep Usage",
  "uid": "claude-code-deep-usage",
  "version": 1
}
